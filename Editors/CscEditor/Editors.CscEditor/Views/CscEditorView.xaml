<UserControl x:Class="Editors.CscEditor.Views.CscEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Editors.CscEditor.ViewModels"
             xmlns:views="clr-namespace:Editors.CscEditor.Views"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisRoot"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0">
            <Button Content="Save" Command="{Binding SaveCommand}" Padding="8,3"/>
            <Separator/>
            <Menu Background="Transparent" VerticalAlignment="Center">
                <MenuItem Header="Add" Padding="8,3"
                          Background="{DynamicResource Popup.Static.Background}"
                          Foreground="{DynamicResource Popup.Static.Foreground}">
                    <MenuItem.Resources>
                        <!-- Forces dark-theme contrast on the dropdown items regardless of ambient
                             styling - this is the only Menu (as opposed to Button+ContextMenu) in
                             the CSC editor, and its submenu popup was rendering with the OS default
                             light chrome instead of the app's dark theme. -->
                        <Style TargetType="MenuItem">
                            <Setter Property="Background" Value="{DynamicResource Popup.Static.Background}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Popup.Static.Foreground}"/>
                        </Style>
                    </MenuItem.Resources>
                    <MenuItem Header="Model..." Command="{Binding AddModelCommand}"/>
                    <MenuItem Header="Variant model..." Command="{Binding AddVariantModelCommand}"/>
                    <MenuItem Header="VFX..." Command="{Binding AddVfxCommand}"/>
                    <MenuItem Header="SFX..." Command="{Binding AddSfxCommand}"/>
                    <MenuItem Header="Animation..." Command="{Binding AddAnimationCommand}"/>
                    <MenuItem Header="Point light" Command="{Binding AddPointLightCommand}"/>
                    <MenuItem Header="Spot light" Command="{Binding AddSpotLightCommand}"/>
                    <MenuItem Header="Camera" Command="{Binding AddCameraCommand}"/>
                    <MenuItem Header="Composite scene..." Command="{Binding AddCompositeSceneCommand}"/>
                    <MenuItem Header="Prefab..." Command="{Binding AddPrefabCommand}"/>
                    <MenuItem Header="Group (empty)" Command="{Binding AddLocatorCommand}"/>
                </MenuItem>
            </Menu>
            <Button Content="Delete" Command="{Binding DeleteSelectedCommand}" IsEnabled="{Binding HasSelection}" Padding="8,3"/>
            <Separator/>
            <Button Content="Move" Command="{Binding GizmoTranslateCommand}" IsEnabled="{Binding HasSelection}" Padding="8,3"/>
            <Button Content="Rotate" Command="{Binding GizmoRotateCommand}" IsEnabled="{Binding HasSelection}" Padding="8,3"/>
            <Button Content="Scale" Command="{Binding GizmoScaleCommand}" IsEnabled="{Binding HasSelection}" Padding="8,3"/>
            <Button Content="Gizmo off" Command="{Binding GizmoOffCommand}" Padding="8,3"/>
            <Separator/>
            <Button Content="Focus" Command="{Binding FocusSelectedCommand}" IsEnabled="{Binding HasSelection}" Padding="8,3"/>
            <Button Content="Look through camera" Command="{Binding LookThroughCameraCommand}"
                    IsEnabled="{Binding SelectedElement.IsCamera, FallbackValue=False}" Padding="8,3"/>
            <Button Content="Reset view" Command="{Binding ResetViewCommand}"
                    IsEnabled="{Binding IsLookingThroughCamera}" Padding="8,3"/>
        </ToolBar>

        <!-- Main area: 3D view | tree + details -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- MinWidth keeps the 3D view from being squeezed smaller than the porthole
                     overlay's own fixed 242px footprint (see below) - avoids it overflowing/clipping
                     against the tree+details panel while looking through a camera. -->
                <ColumnDefinition Width="*" MinWidth="242"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <ContentControl Content="{Binding Scene, Mode=OneTime}"/>

                <!-- Porthole overlay: emulates the in-game 2D framing while looking through a
                     camera. Fixed pixel size (porthole.png's own 242x258 footprint, circular cutout
                     180x180 centred at 115,120 -> offset 25,30) - intentionally does NOT scale with
                     the panel, since it's a fixed-size UI widget in-game, not viewport-relative. -->
                <Grid Visibility="{Binding IsLookingThroughCamera, Converter={StaticResource BoolToVisRoot}}"
                      IsHitTestVisible="False">
                    <!-- Nothing but the porthole itself is visible in-game, so hide the raw render
                         entirely (its own grid/background are also suppressed at the source while
                         looking through a camera - see CscAnimationComponent.ApplyLookThroughCamera). -->
                    <Rectangle Fill="Black"/>

                    <Canvas Width="242" Height="258" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Back art: shows through wherever the circle clip below is transparent. -->
                        <Image Source="{Binding PortholeBackImage}" Canvas.Left="25" Canvas.Top="30"
                               Width="180" Height="180" Stretch="Fill"/>

                        <!-- Live, alpha-preserving snapshot of the 3D render (CscAnimationComponent.
                             PortholeLiveFrame - a throttled CPU readback of RenderEngineComponent's
                             pre-composite render target, not a mirror of the opaque viewport surface -
                             see its CapturePortholeFrame for why), clipped to a circle. -->
                        <Image Source="{Binding PortholeLiveFrame}" Canvas.Left="25" Canvas.Top="30"
                               Width="180" Height="180" Stretch="Fill">
                            <Image.Clip>
                                <EllipseGeometry Center="90,90" RadiusX="90" RadiusY="90"/>
                            </Image.Clip>
                        </Image>

                        <!-- Frame art on top, at its native footprint. -->
                        <Image Source="{Binding PortholeFrameImage}" Width="242" Height="258"/>
                    </Canvas>
                </Grid>
            </Grid>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#FF606060"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="Auto" MinHeight="200"/>
                </Grid.RowDefinitions>

                <!-- Component tree -->
                <GroupBox Grid.Row="0" Header="Components (drag onto a node to re-parent, drop on Root or empty space to detach)">
                    <TreeView x:Name="ComponentTree"
                              ItemsSource="{Binding SceneRootItems}"
                              SelectedItemChanged="ComponentTree_SelectedItemChanged"
                              AllowDrop="True"
                              PreviewMouseLeftButtonDown="ComponentTree_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="ComponentTree_PreviewMouseMove"
                              Drop="ComponentTree_Drop">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type vm:CscSceneRootViewModel}" ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" Foreground="#FFCCCCCC"/>
                                    <TextBlock Text="{Binding Subtitle, StringFormat=' ({0})'}" Foreground="#FF888888" Margin="4,0,0,0"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type vm:CscElementViewModel}" ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" ToolTip="{Binding ReadOnlyReason}">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditable}" Value="False">
                                                    <Setter Property="Opacity" Value="0.45"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="{Binding KindName}" FontWeight="Bold" Margin="0,0,6,0" Foreground="#FF88AACC"/>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="{x:Type TreeViewItem}">
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Detach (make top-level)" Command="{Binding DetachSelectedCommand}"/>
                                <MenuItem Header="Delete" Command="{Binding DeleteSelectedCommand}"/>
                                <MenuItem Header="Focus in 3D view" Command="{Binding FocusSelectedCommand}"/>
                            </ContextMenu>
                        </TreeView.ContextMenu>
                    </TreeView>
                </GroupBox>

                <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Background="#FF606060"/>

                <!-- Details -->
                <GroupBox Grid.Row="2" Header="Details">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="420">
                        <ScrollViewer.Resources>
                            <BooleanToVisibilityConverter x:Key="PanelBoolToVis"/>
                        </ScrollViewer.Resources>
                        <Grid>
                        <StackPanel DataContext="{Binding SelectedElement}" Margin="4" IsEnabled="{Binding IsEditable, FallbackValue=False}"
                                    Visibility="{Binding DataContext.IsElementSelected, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource PanelBoolToVis}, FallbackValue=Collapsed}">
                            <StackPanel.Resources>
                                <Style TargetType="TextBox">
                                    <Setter Property="Margin" Value="2"/>
                                    <Setter Property="MinWidth" Value="60"/>
                                </Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="2"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                                <BooleanToVisibilityConverter x:Key="BoolToVis"/>
                            </StackPanel.Resources>

                            <TextBlock FontWeight="Bold" Text="{Binding DisplayName}"/>
                            <TextBlock Text="{Binding KindName, StringFormat='Type: {0}'}"/>

                            <Grid Visibility="{Binding ShowAssetPath, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding AssetPathLabel}"/>
                                <TextBox Grid.Column="1" Text="{Binding AssetPath}"/>
                            </Grid>

                            <Grid Visibility="{Binding IsSfx, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Event 1 (stop)"/>
                                <TextBox Grid.Column="1" Text="{Binding SfxStopEvent}"/>
                            </Grid>

                            <StackPanel Visibility="{Binding SfxHasSecondEventPair, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Event 2 (start)"/>
                                    <TextBox Grid.Column="1" Text="{Binding SfxEvent2Start}"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Event 2 (stop)"/>
                                    <TextBox Grid.Column="1" Text="{Binding SfxEvent2Stop}"/>
                                </Grid>
                            </StackPanel>

                            <!-- Timing -->
                            <TextBlock FontWeight="Bold" Text="Timing" Margin="2,8,2,0"/>
                            <UniformGrid Columns="4">
                                <TextBlock Text="Begin"/><TextBox Text="{Binding Begin}"/>
                                <TextBlock Text="End"/><TextBox Text="{Binding End}"/>
                            </UniformGrid>
                            <UniformGrid Columns="2">
                                <ComboBox Margin="2" SelectedValue="{Binding TimingMode}" SelectedValuePath="Content">
                                    <ComboBoxItem Content="duration"/>
                                    <ComboBoxItem Content="infinite"/>
                                    <ComboBoxItem Content="pulse"/>
                                </ComboBox>
                                <ComboBox Margin="2" SelectedValue="{Binding AnchorMode}" SelectedValuePath="Content">
                                    <ComboBoxItem Content="free"/>
                                    <ComboBoxItem Content="map_zero_y_to_terrain"/>
                                    <ComboBoxItem Content="map_zero_y_to_terrain_and_align"/>
                                    <ComboBoxItem Content="align_to_terrain"/>
                                </ComboBox>
                            </UniformGrid>

                            <!-- ELEMENT_PERIOD: (flag, speed multiplier, time offset) - in-game confirmed -->
                            <StackPanel Visibility="{Binding HasPeriod, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                                <TextBlock FontWeight="Bold" Text="Period" Margin="2,8,2,0"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox VerticalAlignment="Center" IsChecked="{Binding PeriodFlag}"/>
                                    <TextBlock Grid.Column="1" Text="flag" VerticalAlignment="Center" Margin="2,0,8,0"/>
                                    <TextBlock Grid.Column="2" Text="Speed×"/>
                                    <TextBox Grid.Column="3" Text="{Binding PeriodSpeedMultiplier, StringFormat=0.###}"/>
                                    <TextBlock Grid.Column="4" Text="Offset s" Margin="8,0,2,0"/>
                                    <TextBox Grid.Column="5" Text="{Binding PeriodTimeOffset, StringFormat=0.###}"/>
                                </Grid>
                            </StackPanel>

                            <!-- Transform -->
                            <TextBlock FontWeight="Bold" Text="Transform (channels)" Margin="2,8,2,0"/>
                            <UniformGrid Columns="6">
                                <TextBlock Text="Pos X"/><TextBox Text="{Binding PositionX, StringFormat=0.###}"/>
                                <TextBlock Text="Y"/><TextBox Text="{Binding PositionY, StringFormat=0.###}"/>
                                <TextBlock Text="Z"/><TextBox Text="{Binding PositionZ, StringFormat=0.###}"/>
                                <TextBlock Text="Rot X°"/><TextBox Text="{Binding RotationXDegrees, StringFormat=0.##}"/>
                                <TextBlock Text="Y°"/><TextBox Text="{Binding RotationYDegrees, StringFormat=0.##}"/>
                                <TextBlock Text="Z°"/><TextBox Text="{Binding RotationZDegrees, StringFormat=0.##}"/>
                                <TextBlock Text="Scale"/><TextBox Text="{Binding ScaleValue, StringFormat=0.###}"/>
                                <TextBlock Text="Weight"/><TextBox Text="{Binding WeightValue, StringFormat=0.###}"/>
                            </UniformGrid>

                            <TextBlock FontWeight="Bold" Text="Base placement" Margin="2,8,2,0"/>
                            <UniformGrid Columns="6">
                                <TextBlock Text="Pos X"/><TextBox Text="{Binding BasePositionX, StringFormat=0.###}"/>
                                <TextBlock Text="Y"/><TextBox Text="{Binding BasePositionY, StringFormat=0.###}"/>
                                <TextBlock Text="Z"/><TextBox Text="{Binding BasePositionZ, StringFormat=0.###}"/>
                                <TextBlock Text="Rot X°"/><TextBox Text="{Binding BaseRotationXDegrees, StringFormat=0.##}"/>
                                <TextBlock Text="Y°"/><TextBox Text="{Binding BaseRotationYDegrees, StringFormat=0.##}"/>
                                <TextBlock Text="Z°"/><TextBox Text="{Binding BaseRotationZDegrees, StringFormat=0.##}"/>
                            </UniformGrid>

                            <!-- ELEMENT's trailing Bool (v7/v100 only) - meaning unconfirmed, but
                                 real files show it varying, so it's exposed rather than only
                                 preserved verbatim. Shown for every element kind since it's part of
                                 the base ELEMENT record, not a type-specific field. -->
                            <Grid Visibility="{Binding HasElementTrailingBool, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" Margin="2,4,2,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox VerticalAlignment="Center" IsChecked="{Binding ElementTrailingBool}"/>
                                <TextBlock Grid.Column="1" Text="Trailing flag (meaning unconfirmed)" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </Grid>

                            <!-- Attachment -->
                            <Grid Visibility="{Binding HasAttachParent, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Attach bone index (-1 = origin)"/>
                                <TextBox Grid.Column="1" Text="{Binding AttachBoneIndex}"/>
                            </Grid>

                            <!-- Composite Scene (RootRef): the referenced .csc's own ROOT header
                                 info, shown read-only - IsEnabled is hardcoded False (not tied to
                                 IsEditable) so it stays non-interactive even when this RootRef
                                 element's own fields above are editable. Edit the referenced file
                                 directly instead. -->
                            <StackPanel Visibility="{Binding HasSubScene, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" IsEnabled="False">
                                <TextBlock FontWeight="Bold" Text="Referenced scene (read-only)" Margin="2,8,2,0"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Duration (s)"/>
                                    <TextBox Grid.Column="1" Text="{Binding SubSceneDuration, StringFormat=0.###, Mode=OneWay}"/>
                                </Grid>
                                <TextBlock Text="Focus point" Margin="2,4,2,0"/>
                                <UniformGrid Columns="6">
                                    <TextBlock Text="X"/><TextBox Text="{Binding SubSceneFocusPointX, StringFormat=0.###, Mode=OneWay}"/>
                                    <TextBlock Text="Y"/><TextBox Text="{Binding SubSceneFocusPointY, StringFormat=0.###, Mode=OneWay}"/>
                                    <TextBlock Text="Z"/><TextBox Text="{Binding SubSceneFocusPointZ, StringFormat=0.###, Mode=OneWay}"/>
                                </UniformGrid>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Radius/distance"/>
                                    <TextBox Grid.Column="1" Text="{Binding SubSceneRadius, StringFormat=0.###, Mode=OneWay}"/>
                                </Grid>
                                <Grid Visibility="{Binding SubSceneHasWeatherPath, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Weather/environment"/>
                                    <TextBox Grid.Column="1" Text="{Binding SubSceneWeatherPath, Mode=OneWay}"/>
                                </Grid>
                            </StackPanel>

                            <!-- Lights -->
                            <StackPanel Visibility="{Binding IsLight, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                                <TextBlock FontWeight="Bold" Text="Light" Margin="2,8,2,0"/>
                                <UniformGrid Columns="6">
                                    <TextBlock Text="R"/><TextBox Text="{Binding LightColourR, StringFormat=0.###}"/>
                                    <TextBlock Text="G"/><TextBox Text="{Binding LightColourG, StringFormat=0.###}"/>
                                    <TextBlock Text="B"/><TextBox Text="{Binding LightColourB, StringFormat=0.###}"/>
                                    <TextBlock Text="Intensity"/><TextBox Text="{Binding LightIntensity, StringFormat=0.###}"/>
                                    <TextBlock Text="Range/Len"/><TextBox Text="{Binding LightRange, StringFormat=0.###}"/>
                                </UniformGrid>
                                <UniformGrid Columns="4" Visibility="{Binding IsSpotLight, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                                    <TextBlock Text="Inner°"/><TextBox Text="{Binding SpotInnerAngleDegrees, StringFormat=0.##}"/>
                                    <TextBlock Text="Outer°"/><TextBox Text="{Binding SpotOuterAngleDegrees, StringFormat=0.##}"/>
                                </UniformGrid>
                            </StackPanel>

                            <!-- Camera -->
                            <StackPanel Visibility="{Binding IsCamera, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                                <TextBlock FontWeight="Bold" Text="Camera" Margin="2,8,2,0"/>
                                <UniformGrid Columns="6">
                                    <TextBlock Text="FOV°"/><TextBox Text="{Binding CameraFov, StringFormat=0.##}"/>
                                    <TextBlock Text="Roll°"/><TextBox Text="{Binding CameraRollDegrees, StringFormat=0.##}"/>
                                    <TextBlock Text="Near"/><TextBox Text="{Binding CameraNear, StringFormat=0.###}"/>
                                    <TextBlock Text="Far"/><TextBox Text="{Binding CameraFar, StringFormat=0.###}"/>
                                </UniformGrid>

                                <!-- CAMERA_ELEMENT carries an extra Bool between the roll and near
                                     fields (any version) - meaning unconfirmed, exposed for inspection/editing. -->
                                <Grid Visibility="{Binding HasCameraUnknownFlag, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" Margin="2,4,2,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox VerticalAlignment="Center" IsChecked="{Binding CameraUnknownFlag}"/>
                                    <TextBlock Grid.Column="1" Text="Unknown flag (meaning unconfirmed)" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </Grid>
                            </StackPanel>

                            <!-- ANIMATION_SPLICE_ELEMENT: sibling record alongside ANIMATION_ELEMENT -->
                            <StackPanel Visibility="{Binding HasSplice, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                                <TextBlock FontWeight="Bold" Text="Splice" Margin="2,8,2,0"/>
                                <TextBlock Text="Splices this .anim onto the given bone and its descendants. Bone id is a fairly confident guess; the depth fields and everything after them are less certain."
                                           TextWrapping="Wrap" Foreground="#FF999999" FontStyle="Italic" Margin="2,0,2,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Bone id"/>
                                    <TextBox Grid.Column="1" Text="{Binding SpliceBoneId}" LostFocus="AuxField_LostFocus"/>
                                    <TextBlock Grid.Column="2" Text="Depth A" Margin="8,2,2,2"/>
                                    <TextBox Grid.Column="3" Text="{Binding SpliceDepthA}" LostFocus="AuxField_LostFocus"/>
                                    <TextBlock Grid.Column="4" Text="Depth B" Margin="8,2,2,2"/>
                                    <TextBox Grid.Column="5" Text="{Binding SpliceDepthB}" LostFocus="AuxField_LostFocus"/>
                                </Grid>
                                <TextBlock Text="{Binding SpliceRemainingFieldsDisplay}" TextWrapping="Wrap" Foreground="#FF888888" FontSize="10" Margin="2,2,2,0"/>
                            </StackPanel>

                            <!-- ANIMATION_NODE_TRANSFORM_ELEMENT: this element's own kind - its Transform
                                 (channels) section above drives the bone named here. -->
                            <StackPanel Visibility="{Binding IsAnimationNodeTransform, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                                <TextBlock FontWeight="Bold" Text="Node Transform" Margin="2,8,2,0"/>
                                <TextBlock Text="This element's Transform curves above drive the named bone (and its descendants) instead of placing the element itself."
                                           TextWrapping="Wrap" Foreground="#FF999999" FontStyle="Italic" Margin="2,0,2,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Bone id"/>
                                    <TextBox Grid.Column="1" Text="{Binding NodeTransformBoneId}" LostFocus="AuxField_LostFocus"/>
                                    <TextBlock Grid.Column="2" Text="2nd (signed)" Margin="8,2,2,2"/>
                                    <TextBox Grid.Column="3" Text="{Binding NodeTransformSecondValue}" LostFocus="AuxField_LostFocus"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <!-- Scene root (Composite Scene) details: the .csc's own ROOT header fields -->
                        <StackPanel DataContext="{Binding SelectedSceneRoot}" Margin="4"
                                    Visibility="{Binding DataContext.IsSceneRootSelected, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource PanelBoolToVis}, FallbackValue=Collapsed}">
                            <StackPanel.Resources>
                                <Style TargetType="TextBox">
                                    <Setter Property="Margin" Value="2"/>
                                    <Setter Property="MinWidth" Value="60"/>
                                </Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="2"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </StackPanel.Resources>

                            <TextBlock FontWeight="Bold" Text="Composite Scene"/>
                            <TextBlock Text="ROOT header fields - independent of the computed playback duration shown next to the tree's Root item."
                                       TextWrapping="Wrap" Foreground="#FF999999" FontStyle="Italic" Margin="2,2,2,4"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Duration (s)"/>
                                <TextBox Grid.Column="1" Text="{Binding SceneDuration, StringFormat=0.###}"/>
                            </Grid>

                            <TextBlock FontWeight="Bold" Text="Focus point" Margin="2,8,2,0"/>
                            <UniformGrid Columns="6">
                                <TextBlock Text="X"/><TextBox Text="{Binding FocusPointX, StringFormat=0.###}"/>
                                <TextBlock Text="Y"/><TextBox Text="{Binding FocusPointY, StringFormat=0.###}"/>
                                <TextBlock Text="Z"/><TextBox Text="{Binding FocusPointZ, StringFormat=0.###}"/>
                            </UniformGrid>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Radius/distance"/>
                                <TextBox Grid.Column="1" Text="{Binding Radius, StringFormat=0.###}"/>
                            </Grid>

                            <Grid Visibility="{Binding HasWeatherPath, Converter={StaticResource PanelBoolToVis}, FallbackValue=Collapsed}" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Weather/environment"/>
                                <TextBox Grid.Column="1" Text="{Binding WeatherPath}"/>
                            </Grid>
                        </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </GroupBox>
            </Grid>
        </Grid>

        <!-- Timeline + curve editor -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="170"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="4,2">
                <Button Command="{Binding PlayPauseCommand}" Width="60" Margin="0,0,4,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Content" Value="Play"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                    <Setter Property="Content" Value="Pause"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Stop" Command="{Binding StopCommand}" Width="50"/>
            </StackPanel>

            <!-- Time readout only - scrubbing happens on the curve editor's own ruler below, so
                 the two never fall out of alignment. -->
            <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="4,2,18,2">
                <Run Text="{Binding CurrentTime, StringFormat=0.00, Mode=OneWay}"/><Run Text=" / "/><Run Text="{Binding Duration, StringFormat=0.00, Mode=OneWay}"/><Run Text=" s"/>
            </TextBlock>

            <ListBox Grid.Row="1" Grid.Column="0" ItemsSource="{Binding CurveSeriesList}"
                     SelectedItem="{Binding SelectedCurveSeries, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsVisible, Mode=TwoWay}" Click="CurveVisibility_Click" VerticalAlignment="Center"/>
                            <Rectangle Width="10" Height="10" Fill="{Binding Brush}" Margin="4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <views:CurveEditorControl Grid.Row="1" Grid.Column="1" x:Name="CurveEditor" Margin="0,0,12,0"
                                      SeriesSource="{Binding CurveSeriesList}"
                                      SelectedSeries="{Binding SelectedCurveSeries, Mode=TwoWay}"
                                      CurrentTime="{Binding CurrentTime, Mode=TwoWay}"
                                      Duration="{Binding Duration, Mode=OneWay}"
                                      IsReadOnlyStructure="{Binding CurveStructureLocked, Mode=OneWay}"
                                      IsLooping="{Binding Playback.Loop, Mode=OneWay}"
                                      ElementBegin="{Binding SelectedElement.Begin, Mode=OneWay, FallbackValue=0}"
                                      ElementEnd="{Binding SelectedElement.End, Mode=OneWay, FallbackValue=0}"
                                      ElementTimingMode="{Binding SelectedElement.TimingMode, Mode=OneWay, FallbackValue=''}"/>
        </Grid>

        <!-- Status bar -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock Text="{Binding DisplayName}"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="Unsaved changes" Foreground="Orange">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasUnsavedChanges}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
